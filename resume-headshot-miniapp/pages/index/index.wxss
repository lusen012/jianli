.page {
  padding: 24rpx;
}

.hero,
.panel {
  background: rgba(255, 255, 255, 0.88);
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 18rpx 48rpx rgba(24, 45, 77, 0.08);
  margin-bottom: 24rpx;
}

.eyebrow {
  font-size: 22rpx;
  color: #174ea6;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.title {
  margin-top: 12rpx;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.2;
}

.subtitle {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #5b6777;
  line-height: 1.7;
}

.upload-btn,
.primary,
.secondary {
  border-radius: 20rpx;
}

.upload-btn,
.primary {
  background: linear-gradient(135deg, #174ea6, #0f3470);
  color: #ffffff;
}

.secondary {
  margin-top: 16rpx;
  background: rgba(23, 78, 166, 0.1);
  color: #174ea6;
}

.field {
  margin-top: 24rpx;
}

.label,
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.picker {
  padding: 24rpx;
  border-radius: 18rpx;
  background: #f4f7fb;
  color: #17212d;
}

.switch-row {
  margin-top: 20rpx;
  padding: 18rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
}

.action-row {
  margin-top: 24rpx;
}

.status {
  margin-top: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(23, 78, 166, 0.08);
  color: #174ea6;
  font-size: 26rpx;
  line-height: 1.6;
}

.preview-wrap {
  position: relative;
  width: 100%;
  height: 920rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: linear-gradient(160deg, #d7dfeb, #eff3f8 48%, #c7d5e5);
}

.canvas {
  width: 100%;
  height: 100%;
}

.empty-state {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #48617c;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 700;
}

.empty-text {
  margin-top: 12rpx;
  font-size: 26rpx;
}

.style-note {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #f4f7fb;
  color: #5b6777;
  font-size: 26rpx;
  line-height: 1.7;
}
